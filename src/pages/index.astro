---
import report from '../../data/latest.json';
import archive from '../../data/archive/index.json';
---
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{report.title}</title>
    <meta name="description" content="Report diario sobre IA en español generado con Gemini desde fuentes públicas." />
    <style>
      :root {
        color-scheme: light dark;
        --bg: #f6f7f9;
        --card: #ffffff;
        --text: #111827;
        --muted: #667085;
        --border: #e5e7eb;
        --accent: #0f62fe;
      }
      @media (prefers-color-scheme: dark) {
        :root {
          --bg: #0b1020;
          --card: #111827;
          --text: #f9fafb;
          --muted: #9ca3af;
          --border: #1f2937;
          --accent: #7ab7ff;
        }
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background: var(--bg);
        color: var(--text);
        line-height: 1.6;
      }
      .container {
        max-width: 1040px;
        margin: 0 auto;
        padding: 44px 22px 72px;
      }
      header {
        margin-bottom: 34px;
      }
      .kicker {
        color: var(--accent);
        font-weight: 700;
        letter-spacing: .04em;
        text-transform: uppercase;
        font-size: .82rem;
      }
      h1 {
        font-size: clamp(2.1rem, 6vw, 4.2rem);
        line-height: 1.02;
        margin: 10px 0 18px;
      }
      .summary {
        max-width: 820px;
        font-size: 1.08rem;
        color: var(--muted);
      }
      .grid {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 280px;
        gap: 28px;
        align-items: start;
      }
      @media (max-width: 880px) {
        .grid { grid-template-columns: 1fr; }
      }
      section { margin-bottom: 42px; }
      h2 {
        margin: 0 0 18px;
        font-size: 1.55rem;
      }
      article, aside {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 18px;
        padding: 22px;
        margin-bottom: 16px;
        box-shadow: 0 1px 2px rgb(0 0 0 / 4%);
      }
      article h3 {
        margin: 0 0 10px;
        line-height: 1.25;
      }
      a { color: var(--accent); text-decoration: none; }
      a:hover { text-decoration: underline; }
      .meta, .source, .archive-item {
        color: var(--muted);
        font-size: .93rem;
      }
      .tag {
        display: inline-flex;
        align-items: center;
        border: 1px solid var(--border);
        border-radius: 999px;
        padding: 4px 9px;
        margin: 4px 6px 4px 0;
        font-size: .82rem;
        color: var(--muted);
      }
      .note {
        border-left: 4px solid var(--accent);
        padding-left: 14px;
        color: var(--muted);
      }
      ul.archive {
        list-style: none;
        padding: 0;
        margin: 0;
      }
      ul.archive li {
        padding: 10px 0;
        border-bottom: 1px solid var(--border);
      }
      ul.archive li:last-child { border-bottom: 0; }
      footer {
        margin-top: 38px;
        color: var(--muted);
        font-size: .92rem;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <header>
        <div class="kicker">AI Daily Brief con Gemini</div>
        <h1>{report.title}</h1>
        <p class="summary">{report.executive_summary}</p>
        <p class="meta">Modo: {report.mode} · Idioma: español · Última generación: {report.date}</p>
      </header>

      <div class="grid">
        <main>
          <section>
            <h2>Noticias importantes</h2>
            {report.news.map((item) => (
              <article>
                <p class="meta">{item.published_date} · {item.category}</p>
                <h3><a href={item.url} target="_blank" rel="noreferrer">{item.headline}</a></h3>
                <p>{item.summary}</p>
                <p class="note"><strong>Por qué importa:</strong> {item.why_it_matters}</p>
                <p class="source">Fuente: <a href={item.url} target="_blank" rel="noreferrer">{item.source}</a></p>
              </article>
            ))}
          </section>

          <section>
            <h2>Lecturas y papers recomendados</h2>
            {report.papers.map((paper) => (
              <article>
                <p class="meta">{paper.published_date}</p>
                <h3><a href={paper.url} target="_blank" rel="noreferrer">{paper.title}</a></h3>
                <p>{paper.summary}</p>
                <p class="note"><strong>Relevancia técnica:</strong> {paper.technical_relevance}</p>
                <p>{paper.tags.map((tag) => <span class="tag">{tag}</span>)}</p>
                <p class="source">Fuente: <a href={paper.url} target="_blank" rel="noreferrer">{paper.source}</a></p>
              </article>
            ))}
          </section>
        </main>

        <aside>
          <h2>Histórico</h2>
          <ul class="archive">
            {archive.slice(0, 20).map((item) => (
              <li>
                <a href={item.file}>{item.date}</a>
                <div class="archive-item">{item.news_count} noticias · {item.papers_count} papers</div>
              </li>
            ))}
          </ul>
        </aside>
      </div>

      <footer>
        Generado automáticamente con GitHub Actions, feeds públicos, arXiv y Gemini API free tier.
      </footer>
    </div>
  </body>
</html>
