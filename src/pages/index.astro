---
import report from "../../data/latest.json";
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <title>{report.title}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={report.executive_summary} />
    <style>
      :root {
        color-scheme: light;
        --bg: #f7f7f8;
        --card: #ffffff;
        --text: #111827;
        --muted: #6b7280;
        --border: #e5e7eb;
      }

      body {
        max-width: 960px;
        margin: 0 auto;
        padding: 48px 24px;
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        line-height: 1.6;
        background: var(--bg);
        color: var(--text);
      }

      header {
        margin-bottom: 40px;
      }

      .date {
        color: var(--muted);
        font-size: 0.95rem;
        margin-bottom: 8px;
      }

      h1 {
        font-size: clamp(2rem, 5vw, 3.25rem);
        line-height: 1.05;
        margin: 0 0 18px;
        letter-spacing: -0.04em;
      }

      h2 {
        margin-top: 48px;
        margin-bottom: 18px;
        font-size: 1.5rem;
      }

      article {
        background: var(--card);
        padding: 24px;
        border: 1px solid var(--border);
        border-radius: 18px;
        margin-bottom: 18px;
        box-shadow: 0 8px 24px rgba(15, 23, 42, 0.04);
      }

      h3 {
        margin-top: 0;
        margin-bottom: 12px;
        font-size: 1.25rem;
        line-height: 1.3;
      }

      a {
        color: #1d4ed8;
        text-decoration: none;
      }

      a:hover {
        text-decoration: underline;
      }

      .tag {
        display: inline-block;
        font-size: 0.8rem;
        color: #374151;
        background: #f3f4f6;
        border: 1px solid var(--border);
        padding: 4px 8px;
        border-radius: 999px;
        margin: 4px 6px 0 0;
      }

      .meta {
        color: var(--muted);
      }
    </style>
  </head>

  <body>
    <header>
      <p class="date">{report.date}</p>
      <h1>{report.title}</h1>
      <p>{report.executive_summary}</p>
    </header>

    <main>
      <h2>Noticias importantes</h2>

      {report.news.map((item) => (
        <article>
          <h3>{item.headline}</h3>
          <p>{item.summary}</p>
          <p><strong>Por qué importa:</strong> {item.why_it_matters}</p>
          <p class="meta">
            <strong>Fuente:</strong>{" "}
            <a href={item.url} target="_blank" rel="noreferrer">
              {item.source}
            </a>
          </p>
          <span class="tag">{item.category}</span>
        </article>
      ))}

      <h2>Lecturas y papers recomendados</h2>

      {report.papers.map((paper) => (
        <article>
          <h3>{paper.title}</h3>
          <p>{paper.summary}</p>
          <p><strong>Relevancia técnica:</strong> {paper.technical_relevance}</p>
          <p class="meta">
            <strong>Fuente:</strong>{" "}
            <a href={paper.url} target="_blank" rel="noreferrer">
              {paper.source}
            </a>
          </p>
          <p>
            {paper.tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </p>
        </article>
      ))}
    </main>
  </body>
</html>
