---
import fs from 'node:fs';
import path from 'node:path';

export async function getStaticPaths() {
  const archiveDir = path.resolve('./data/archive');
  if (!fs.existsSync(archiveDir)) return [];
  return fs.readdirSync(archiveDir)
    .filter((file) => file.endsWith('.json') && file !== 'index.json')
    .map((file) => ({ params: { date: file.replace('.json', '') } }));
}

const { date } = Astro.params;
const reportPath = path.resolve(`./data/archive/${date}.json`);
const report = JSON.parse(fs.readFileSync(reportPath, 'utf-8'));
---
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{report.title}</title>
    <style>
      body { max-width: 900px; margin: 0 auto; padding: 44px 22px 72px; font-family: system-ui, sans-serif; line-height: 1.6; }
      article { border: 1px solid #ddd; border-radius: 16px; padding: 22px; margin: 16px 0; }
      a { color: #0f62fe; text-decoration: none; }
      a:hover { text-decoration: underline; }
      .meta, .source { color: #667085; font-size: .93rem; }
      .tag { display: inline-block; border: 1px solid #ddd; border-radius: 999px; padding: 4px 9px; margin-right: 6px; font-size: .82rem; color: #667085; }
      .note { border-left: 4px solid #0f62fe; padding-left: 14px; color: #667085; }
    </style>
  </head>
  <body>
    <p><a href="/ai-daily-brief/">← Volver al último report</a></p>
    <h1>{report.title}</h1>
    <p>{report.executive_summary}</p>

    <h2>Noticias importantes</h2>
    {report.news.map((item) => (
      <article>
        <p class="meta">{item.published_date} · {item.category}</p>
        <h3><a href={item.url} target="_blank" rel="noreferrer">{item.headline}</a></h3>
        <p>{item.summary}</p>
        <p class="note"><strong>Por qué importa:</strong> {item.why_it_matters}</p>
        <p class="source">Fuente: <a href={item.url} target="_blank" rel="noreferrer">{item.source}</a></p>
      </article>
    ))}

    <h2>Lecturas y papers recomendados</h2>
    {report.papers.map((paper) => (
      <article>
        <p class="meta">{paper.published_date}</p>
        <h3><a href={paper.url} target="_blank" rel="noreferrer">{paper.title}</a></h3>
        <p>{paper.summary}</p>
        <p class="note"><strong>Relevancia técnica:</strong> {paper.technical_relevance}</p>
        <p>{paper.tags.map((tag) => <span class="tag">{tag}</span>)}</p>
        <p class="source">Fuente: <a href={paper.url} target="_blank" rel="noreferrer">{paper.source}</a></p>
      </article>
    ))}
  </body>
</html>
